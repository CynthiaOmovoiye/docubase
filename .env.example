# docbase — Environment Variables
# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development               # development | staging | production
APP_SECRET_KEY=change-me-to-a-long-random-string
APP_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
# Optional: comma-separated browser origins for CORS. If empty, FRONTEND_URL is used and in
# development the same URL with localhost <-> 127.0.0.1 is also allowed (fixes Vite CORS when
# you open the app via 127.0.0.1 instead of localhost). Use # for comments — not // (dotenv
# will treat // as part of the value).
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
#
# Local UI (`cd frontend && npm run dev`): omit VITE_API_URL (or leave it unset) in frontend/.env.local so the
# app uses same-origin /api/v1 and Vite proxies to the API (see API_PROXY_TARGET in vite.config).
# Setting VITE_API_URL=http://localhost:8000 forces cross-origin calls and needs CORS + a
# reachable API from the browser.

# ─── Database ─────────────────────────────────────────────────────────────────
# Use @db when running backend in Docker Compose; use @localhost when running the API on the host.
DATABASE_URL=postgresql+asyncpg://doctwin_user:doctwin_pass@localhost:5432/doctwin_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ─── Redis ────────────────────────────────────────────────────────────────────
# With Docker Compose, backend/worker use redis://redis:6379/0 (set in docker-compose.yml). For a backend running on your host against Compose, publish redis in compose or point this at your local Redis.
REDIS_URL=redis://localhost:6379/0

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-another-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Optional: `make seed` creates or promotes a superuser (access /admin in the UI + /api/v1/admin/*)
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=change-me-8-chars-min

# ─── LLM Provider ─────────────────────────────────────────────────────────────
# Default path: OpenRouter (OpenAI-compatible API; no OpenAI account required).
# Keys: https://openrouter.ai/keys — Models: https://openrouter.ai/models
LLM_PROVIDER=openrouter            # openrouter | openai | anthropic | local
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini
# Optional attribution for OpenRouter rankings (recommended for production)
OPENROUTER_HTTP_REFERER=https://your-site.example
OPENROUTER_APP_TITLE=docbase

# Direct OpenAI (when you have an OpenAI API key and want the official endpoint)
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.2

# Chat quality gate: synchronous judge + optional regeneration before the reply is saved.
# When true, the passive post-hoc dimensional evaluator is skipped (saves a second LLM call).
# CHAT_QUALITY_GATE_ENABLED=true
# CHAT_QUALITY_GATE_MAX_REGENERATIONS=2

# ─── Embeddings ───────────────────────────────────────────────────────────────
# Embeddings power ingestion, retrieval, graph search, and memory generation.
EMBEDDING_PROVIDER=local           # openai | jina | voyage | local
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
EMBEDDING_FALLBACK_PROVIDER=
EMBEDDING_FALLBACK_MODEL=

# Jina AI embeddings — useful primary provider for dev and production.
# The batching knobs below help stay under token-per-minute limits on larger ingests.
JINA_API_KEY=
JINA_EMBED_BATCH_SIZE=32
JINA_EMBED_BATCH_DELAY_MS=1500
JINA_EMBED_MAX_RETRIES=3
JINA_EMBED_RETRY_BASE_DELAY_MS=2000
JINA_EMBED_RETRY_MAX_DELAY_MS=15000

# Voyage AI embeddings — optional backup provider when Jina is rate-limited.
VOYAGE_API_KEY=

# ─── Storage ──────────────────────────────────────────────────────────────────
# For uploaded files (PDFs, etc.)
STORAGE_BACKEND=local             # local | s3
# /tmp is world-readable on Linux — use a restricted path in production.
# Ensure this directory exists and has mode 0700 before starting the API.
# In production, prefer STORAGE_BACKEND=s3 instead.
STORAGE_LOCAL_PATH=/var/lib/docbase/uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1

# ─── Google Drive OAuth (integrations) ───────────────────────────────────────
# Create OAuth client credentials in Google Cloud Console; redirect URI must be
#   {APP_BASE_URL}/api/v1/integrations/google_drive/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Policy / Safety ──────────────────────────────────────────────────────────
# Patterns always blocked at ingestion regardless of user config
POLICY_BLOCKED_FILE_PATTERNS=.env,.env.*,*.pem,*.key,*.p12,*.pfx,secrets.*,credentials.*
POLICY_SECRET_SCAN_ENABLED=true

# ─── Observability ────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json                   # json | text
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# Local: do not set COMPOSE_FILE (docker-compose.yml uses json-file log rotation).
# EC2: deploy-backend.sh appends COMPOSE_FILE=docker-compose.yml:docker-compose.awslogs.yml
# so backend/worker logs ship to CloudWatch. Also set the region and environment.
AWS_DEFAULT_REGION=us-east-1
ENVIRONMENT=dev                   # dev | test | prod — CloudWatch log group path when using awslogs merge file

# ─── Email (for auth flows) ───────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@yourdomain.com
